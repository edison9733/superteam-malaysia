# ════════════════════════════════════════════════════════════
# Superteam Malaysia — Environment Variables
# Copy this file to .env.local and fill in your values
# ════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Site Configuration ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://superteam.my
NEXT_PUBLIC_SITE_NAME=Superteam Malaysia

# ── Luma (Events) ──────────────────────────────────────────
# Get your API key from https://docs.lu.ma/reference/getting-started
LUMA_API_KEY=
LUMA_CALENDAR_ID=superteammy
NEXT_PUBLIC_LUMA_CALENDAR_URL=https://lu.ma/superteammy

# ── ISR Revalidation ───────────────────────────────────────
# On-demand revalidation secret (generate: openssl rand -hex 32)
REVALIDATION_SECRET=your-secret-here

# ── Social Links ────────────────────────────────────────────
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/SuperteamMY
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/superteammy
NEXT_PUBLIC_TWITTER_URL=https://x.com/SuperteamMY

# ── ISR Revalidation (seconds) ──────────────────────────────
# How often the site rebuilds to pick up CMS changes
REVALIDATION_INTERVAL=60
